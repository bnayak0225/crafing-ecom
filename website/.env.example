# Server-side REST API URL (mock catalog/cart — cafing-ecom/api)
API_URL=http://localhost:3001

# Crafing GraphQL API (saved designs — crafing/api)
# Leave empty in dev to use Next.js /api/v1/graphql rewrite
NEXT_PUBLIC_CRAFING_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_CRAFING_API_TOKEN=creator-token
GRAPHQL_URL=http://127.0.0.1:4000

# Optional browser REST base (leave empty to use Next.js /api rewrites in dev)
NEXT_PUBLIC_API_URL=

# image-resize (background remover) — browser WebSocket connects directly to 4001
NEXT_PUBLIC_IMAGE_RESIZE_GRAPHQL_WS_URL=ws://127.0.0.1:4001/graphql
# HTTP tools (resize, probe) — leave empty in dev to proxy via Next.js /api/v1/tools/* (no CORS)
NEXT_PUBLIC_IMAGE_RESIZE_URL=
# Server-side rewrite target for image-resize HTTP (next.config.ts)
IMAGE_RESIZE_URL=http://127.0.0.1:4001
# Optional when image-resize has RESIZE_API_KEY set
# NEXT_PUBLIC_IMAGE_RESIZE_API_KEY=

# External image-editor — opens /design?workId=
NEXT_PUBLIC_IMAGE_EDITOR_URL=http://localhost:5174
NEXT_PUBLIC_DEFAULT_TEMPLATE_ID=tpl-print
